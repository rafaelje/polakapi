{
  "name": "polakapi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/tauri-dev.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rs:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rs:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rs:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "rs:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rs:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run rs:fmt:check && pnpm run rs:clippy && pnpm run rs:test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
